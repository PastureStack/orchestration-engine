<included>

    <appender name="SYNC_LOGSTASH_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${aggregationLevel}</level>
        </filter>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
    </appender>
    <appender name="LOGSTASH_CONSOLE" class="ch.qos.logback.classic.AsyncAppender" >
        <appender-ref ref="SYNC_LOGSTASH_CONSOLE" />
    </appender>

    <root>
        <appender-ref ref="LOGSTASH_CONSOLE" />
    </root>
</included>
