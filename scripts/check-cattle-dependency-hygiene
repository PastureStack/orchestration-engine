    echo "Blocked Maven test-selection drift; keep Surefire/Failsafe include/exclude patterns, group filters, selected-test properties, fail-if-no-tests behavior, and skip-after-failure behavior unchanged unless a dedicated JDK25 test coverage slice validates the narrowed matrix" >&2
    echo "$maven_test_selection_configs" >&2
    fail=1
fi

