helper_runtime_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOORS = {
    "aspectjweaver": ((1, 9, 25), "1.9.25", (1, 9), re.compile(r"^aspectjweaver-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")),
    "aspectjrt": ((1, 9, 25), "1.9.25", (1, 9), re.compile(r"^aspectjrt-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")),
    "janino": ((3, 1, 12), "3.1.12", (3,), re.compile(r"^janino-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")),
    "commons-compiler": ((3, 1, 12), "3.1.12", (3,), re.compile(r"^commons-compiler-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")),
    "javassist": ((3, 31, 0), "3.31.0-GA", (3,), re.compile(r"^javassist-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")),
    "logstash-logback-encoder": ((8, 1, 0), "8.1", (8,), re.compile(r"^logstash-logback-encoder-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")),
}
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []

def line_matches(version, line):
    return version[:len(line)] == line

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path:
            continue
        for artifact, (floor_tuple, floor_text, line, pattern) in FLOORS.items():
            match = pattern.match(jar.name)
            if not match:
                continue
            major, minor, patch, qualifier = match.groups()
            version = (int(major), int(minor), int(patch or "0"))
            if not line_matches(version, line):
                failures.append(f"{path}: {artifact} is outside the reviewed compatibility line")
            elif version < floor_tuple:
                failures.append(f"{path}: {artifact} < {floor_text}")
            elif UNREVIEWED_QUALIFIER.search(qualifier):
                failures.append(f"{path}: {artifact} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
