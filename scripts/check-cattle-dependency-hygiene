            name = local_name(child.tag)
            value = text(child)
            yield f"compilerArguments/{name}", f"-{name} {value}".strip()
            if name in BLOCKED_COMPILER_ARGUMENT_NAMES:
                yield f"compilerArguments/{name}", f"-{name}"

failures = []

for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for properties in root.findall(".//m:properties", NS):
        for prop in list(properties):
            name = local_name(prop.tag)
            if name in BLOCKED_PROPERTIES:
                failures.append(f"{pom}: Maven compiler annotation processor property <{name}> is blocked until processor classpath and generated-source compatibility are reviewed")

    for dependency in root.findall(".//m:dependency", NS):
        dep_type = (dependency.findtext("m:type", default="", namespaces=NS) or "").strip()
        if dep_type in PROCESSOR_DEPENDENCY_TYPES:
            group = (dependency.findtext("m:groupId", default="", namespaces=NS) or "").strip()
            artifact = (dependency.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
            failures.append(f"{pom}: dependency {group}:{artifact} uses annotation processor type <type>{dep_type}</type> without a dedicated processor compatibility slice")

    for plugin in root.findall(".//m:plugin", NS):
        if plugin_key(plugin) != COMPILER_PLUGIN:
            continue

        for configuration in plugin.findall(".//m:configuration", NS):
            for child in list(configuration):
                name = local_name(child.tag)
                if name in BLOCKED_CONFIGURATION:
                    value = text(child)
                    rendered = f"<{name}>{value}</{name}>" if value else f"<{name}>"
                    failures.append(f"{pom}: Maven compiler plugin annotation processor configuration {rendered} is blocked until generated sources and JDK25 processor behavior are reviewed")

            for source, value in compiler_arg_texts(configuration):
                if PROCESSOR_ARGUMENT.search(value):
                    failures.append(f"{pom}: Maven compiler plugin {source} passes annotation processor javac argument `{value}` without a dedicated processor compatibility slice")

print("\n".join(failures))
sys.exit(0)
PY
)
