ALLOWED_DEPENDENCY_PROFILE = (Path("code/packaging/app/pom.xml"), "dev")

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def child_names(element):
    return [local_name(child.tag) for child in list(element)]

def validate_property_activation(failures, pom, profile, profile_id, property_name):
    activation = profile.find("m:activation", NS)
    if activation is None:
        failures.append(f"{pom}: reviewed Maven profile {profile_id} must keep the {property_name} property activation")
        return
    for name in child_names(activation):
        if name != "property":
            failures.append(f"{pom}: reviewed Maven profile {profile_id} contains blocked activation <{name}>")
    prop = activation.find("m:property", NS)
    prop_name = (prop.findtext("m:name", default="", namespaces=NS) if prop is not None else "").strip()
    prop_value = (prop.findtext("m:value", default="", namespaces=NS) if prop is not None else "").strip()
    if prop_name != property_name or prop_value:
        failures.append(f"{pom}: reviewed Maven profile {profile_id} must activate only on property {property_name} without a value")

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for profile in root.findall("m:profiles/m:profile", NS):
        profile_id = (profile.findtext("m:id", default="", namespaces=NS) or "").strip()
        key = (pom, profile_id)
        if key in ALLOWED_MODULE_PROFILES:
            property_name, expected_modules = ALLOWED_MODULE_PROFILES[key]
            for name in child_names(profile):
                if name not in {"id", "activation", "modules"}:
                    failures.append(f"{pom}: reviewed Maven profile {profile_id} contains blocked <{name}> element")
            validate_property_activation(failures, pom, profile, profile_id, property_name)
            modules = tuple(
                (module.text or "").strip()
                for module in profile.findall("m:modules/m:module", NS)
            )
            if modules != expected_modules:
                failures.append(f"{pom}: reviewed Maven profile {profile_id} module list changed from the audited build graph")
            continue

        if key != ALLOWED_DEPENDENCY_PROFILE:
            failures.append(f"{pom}: Maven profile {profile_id or '(no id)'} is not in the reviewed allowlist and can mutate the effective build")
            continue

        for name in child_names(profile):
            if name not in {"id", "activation", "dependencies"}:
                failures.append(f"{pom}: reviewed Maven profile {profile_id} contains blocked <{name}> element")

        validate_property_activation(failures, pom, profile, profile_id, "!release")

        dependencies = profile.find("m:dependencies", NS)
        deps = dependencies.findall("m:dependency", NS) if dependencies is not None else []
        if len(deps) != 1:
            failures.append(f"{pom}: reviewed Maven profile {profile_id} must declare exactly the reactor-local cattle-dev dependency")
            continue

        dep = deps[0]
        for name in child_names(dep):
            if name not in {"groupId", "artifactId", "version"}:
                failures.append(f"{pom}: reviewed Maven profile {profile_id} dependency contains blocked <{name}> element")
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if (group, artifact, version) != ("io.cattle", "cattle-dev", "${project.version}"):
            failures.append(f"{pom}: reviewed Maven profile {profile_id} dependency must remain io.cattle:cattle-dev:${{project.version}}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_profile_surfaces" ]; then
    echo "Blocked unreviewed Maven profile surface; keep profiles limited to the reviewed root module profiles and packaging/app dev profile so activation cannot rewrite dependencies, repositories, properties, plugins, or build behavior implicitly" >&2
    echo "$maven_profile_surfaces" >&2
    fail=1
fi

maven_project_config_surfaces=$(
    python3 - <<'PY'
import hashlib
import sys
from pathlib import Path

ALLOWED_MVN_DIRS = {
    Path(".mvn"),
    Path(".mvn/wrapper"),
}
ALLOWED_MVN_FILES = {
    Path(".mvn/wrapper/maven-wrapper.jar"),
    Path(".mvn/wrapper/maven-wrapper.properties"),
}
BLOCKED_PROJECT_CONFIGS = {
    Path(".mvn/extensions.xml"): "core extension artifacts",
    Path(".mvn/maven.config"): "project-scoped Maven CLI flags",
    Path(".mvn/jvm.config"): "project-scoped JVM flags",
}
EXPECTED_WRAPPER_PROPERTIES = (
    "distributionUrl=https://repo1.maven.org/maven2/org/apache/maven/apache-maven/3.9.14/apache-maven-3.9.14-bin.zip",
    "distributionSha256Sum=55fadd669532a3205d5db95f490bf13971d8b0843526f407f29db0e61f074ab3",
    "wrapperSha256Sum=c4ad2d091e089e6293664b62a07fa6538eb9b74612247d4b51812ad4c571d3a1",
)
EXPECTED_WRAPPER_JAR_SHA256 = "c4ad2d091e089e6293664b62a07fa6538eb9b74612247d4b51812ad4c571d3a1"
WRAPPER_SCRIPT_GUARDS = {
    Path("mvnw"): {
        "POSIX local Maven preference": "command -v mvn",
        "POSIX wrapper force override": "RC16_MAVEN_WRAPPER_FORCE",
        "POSIX wrapper download opt-in": "RC16_ALLOW_MAVEN_WRAPPER_DOWNLOAD",
        "POSIX wrapper download disabled message": "RC16 Maven wrapper download is disabled by default.",
    },
    Path("mvnw.cmd"): {
        "Windows local Maven preference": "where mvn.cmd",
        "Windows wrapper force override": "RC16_MAVEN_WRAPPER_FORCE",
        "Windows wrapper download opt-in": "RC16_ALLOW_MAVEN_WRAPPER_DOWNLOAD",
        "Windows wrapper download disabled message": "RC16 Maven wrapper download is disabled by default.",
    },
}

failures = []

for path, reason in BLOCKED_PROJECT_CONFIGS.items():
    if path.exists():
        failures.append(f"{path}: repo-local Maven project config can inject {reason}")

mvn_dir = Path(".mvn")
if not mvn_dir.is_dir():
    failures.append(".mvn: reviewed Maven wrapper directory is missing")
else:
    for path in sorted(mvn_dir.rglob("*")):
        if path.is_dir():
            if path not in ALLOWED_MVN_DIRS:
                failures.append(f"{path}: unreviewed Maven project configuration directory")
            continue
        if path not in ALLOWED_MVN_FILES:
            failures.append(f"{path}: unreviewed Maven project configuration file")

for path in sorted(ALLOWED_MVN_FILES | {Path("mvnw"), Path("mvnw.cmd")}):
    if not path.is_file():
        failures.append(f"{path}: reviewed Maven wrapper file is missing")

wrapper_properties = Path(".mvn/wrapper/maven-wrapper.properties")
if wrapper_properties.is_file():
    properties = tuple(
        line.strip()
        for line in wrapper_properties.read_text(encoding="utf-8").splitlines()
        if line.strip() and not line.lstrip().startswith("#")
    )
    if properties != EXPECTED_WRAPPER_PROPERTIES:
        failures.append(f"{wrapper_properties}: Maven wrapper properties changed from the audited distribution URL and SHA-256 checksum set")

wrapper_jar = Path(".mvn/wrapper/maven-wrapper.jar")
if wrapper_jar.is_file():
    actual_wrapper_sha256 = hashlib.sha256(wrapper_jar.read_bytes()).hexdigest()
    if actual_wrapper_sha256 != EXPECTED_WRAPPER_JAR_SHA256:
        failures.append(f"{wrapper_jar}: Maven wrapper jar SHA-256 {actual_wrapper_sha256} does not match the audited wrapperSha256Sum")

for path, required_tokens in WRAPPER_SCRIPT_GUARDS.items():
    if not path.is_file():
        continue
    content = path.read_text(encoding="utf-8").replace("\r\n", "\n")
    for description, token in required_tokens.items():
        if token not in content:
            failures.append(f"{path}: reviewed Maven wrapper script is missing the {description} guard")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_project_config_surfaces" ]; then
    echo "Blocked unreviewed Maven project configuration surface; keep repo-local Maven execution configuration limited to reviewed wrapper files so project config cannot add core extensions, CLI flags, JVM flags, or alternate Maven behavior implicitly" >&2
    echo "$maven_project_config_surfaces" >&2
    fail=1
fi

maven_build_gate_skip_configs=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
BLOCKED_PROPERTIES = {
    "checkstyle.skip",
    "checkstyle.skipExec",
    "enforcer.skip",
    "failsafe.skip",
    "maven.test.failure.ignore",
    "maven.test.skip",
    "maven.test.skip.exec",
    "skipITs",
    "skipTests",
    "surefire.skip",
    "testFailureIgnore",
}
PLUGIN_GATES = {
    ("org.apache.maven.plugins", "maven-checkstyle-plugin"): {
        "blocked_any": {"skip", "skipExec"},
        "blocked_false": {"failOnViolation", "failsOnError"},
        "blocked_true": set(),
    },
    ("org.apache.maven.plugins", "maven-enforcer-plugin"): {
        "blocked_any": {"skip"},
        "blocked_false": {"fail"},
        "blocked_true": set(),
    },
    ("org.apache.maven.plugins", "maven-failsafe-plugin"): {
        "blocked_any": {"skip", "skipITs", "skipTests"},
        "blocked_false": set(),
        "blocked_true": {"testFailureIgnore"},
    },
    ("org.apache.maven.plugins", "maven-surefire-plugin"): {
        "blocked_any": {"skip", "skipTests", "maven.test.skip"},
        "blocked_false": set(),
        "blocked_true": {"testFailureIgnore"},
    },
}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def element_text(element):
    return "".join(element.itertext()).strip()

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for properties in root.findall(".//m:properties", NS):
        for prop in list(properties):
            name = local_name(prop.tag)
            if name in BLOCKED_PROPERTIES:
                failures.append(f"{pom}: Maven build gate bypass property <{name}> is declared")

    for plugin in root.findall(".//m:plugin", NS):
        group = (plugin.findtext("m:groupId", default="org.apache.maven.plugins", namespaces=NS) or "org.apache.maven.plugins").strip()
        artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        gate = PLUGIN_GATES.get((group, artifact))
        if gate is None:
            continue

        for configuration in plugin.findall(".//m:configuration", NS):
            for element in configuration.iter():
                if element is configuration:
                    continue
                name = local_name(element.tag)
                text = element_text(element).lower()
                if name in gate["blocked_any"]:
                    failures.append(f"{pom}: Maven build gate plugin {group}:{artifact} declares bypass <{name}>")
                if name in gate["blocked_false"] and text == "false":
                    failures.append(f"{pom}: Maven build gate plugin {group}:{artifact} weakens failure handling with <{name}>false</{name}>")
                if name in gate["blocked_true"] and text == "true":
                    failures.append(f"{pom}: Maven build gate plugin {group}:{artifact} ignores failures with <{name}>true</{name}>")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_build_gate_skip_configs" ]; then
    echo "Blocked Maven build gate skip configuration; keep Enforcer, Checkstyle, Surefire, and Failsafe active in POMs so source, toolchain, and test gates cannot be disabled implicitly" >&2
    echo "$maven_build_gate_skip_configs" >&2
    fail=1
fi

