#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")/.."

resolve_python_cmd() {
    for candidate in "${PYTHON:-}" python3 python; do
        [ -n "$candidate" ] || continue
        if "$candidate" -c 'import sys; sys.exit(0)' >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

python_cmd="$(resolve_python_cmd)" || {
    echo "python3 or python is required for cattle dependency hygiene" >&2
    exit 1
}

python3() {
    command "$python_cmd" "$@"
}

fail=0

if ! scripts/check-cattle-suppression-inventory; then
    fail=1
fi

if ! scripts/check-cattle-deprecation-inventory; then
    fail=1
fi

if grep -RIn --include='pom.xml' --exclude-dir=target --exclude-dir=.git \
    -E '<artifactId>(fluent-hc|httpclient|httpcore|geronimo-servlet_3\.0_spec)</artifactId>' .; then
    echo "Blocked legacy dependency found in Maven POMs" >&2
    fail=1
fi

if grep -RIn --include='pom.xml' --exclude-dir=target --exclude-dir=.git \
    -E '<artifactId>(commons-beanutils|commons-fileupload)</artifactId>' .; then
    echo "Blocked legacy Commons BeanUtils/FileUpload dependency found in Maven POMs; use commons-beanutils2 and commons-fileupload2 Jakarta artifacts" >&2
    fail=1
fi

legacy_commons_lang_collections_dependencies=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
blocked_artifacts = {"commons-lang", "commons-collections"}

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue
    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if artifact in blocked_artifacts:
            failures.append(f"{pom}: {group}:{artifact}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$legacy_commons_lang_collections_dependencies" ]; then
    echo "Blocked legacy Commons Lang 2.x/Collections 3.x dependency found in Maven POMs; use commons-lang3 and commons-collections4" >&2
    echo "$legacy_commons_lang_collections_dependencies" >&2
    fail=1
fi

commons_core_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOORS = {
    ("commons-io", "commons-io"): ((2, 22, 0, 999), "2.22.0", "Commons IO", (2,)),
    ("org.apache.commons", "commons-compress"): ((1, 28, 0, 999), "1.28.0", "Commons Compress", (1,)),
    ("org.apache.commons", "commons-text"): ((1, 15, 0, 999), "1.15.0", "Commons Text", (1,)),
    ("org.apache.commons", "commons-lang3"): ((3, 20, 0, 999), "3.20.0", "Commons Lang3", (3,)),
    ("org.apache.commons", "commons-collections4"): ((4, 5, 0, 999), "4.5.0", "Commons Collections4", (4,)),
    ("org.apache.commons", "commons-beanutils2"): ((2, 0, 0, 2), "2.0.0-M2", "Commons BeanUtils2", (2,)),
    ("org.apache.commons", "commons-fileupload2-jakarta-servlet6"): ((2, 0, 0, 5), "2.0.0-M5", "Commons FileUpload2 Jakarta Servlet6", (2,)),
}
REVIEWED_PRERELEASES = {
    ("org.apache.commons", "commons-beanutils2"): {"2.0.0-M2"},
    ("org.apache.commons", "commons-fileupload2-jakarta-servlet6"): {"2.0.0-M5"},
}
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:-M(\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch, milestone = match.groups()
    return (int(major), int(minor), int(patch or "0"), int(milestone or "999"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

def line_matches(parsed, line):
    return parsed[:len(line)] == line

def has_unreviewed_qualifier(group, artifact, version):
    normalized = version.strip()
    if not UNREVIEWED_QUALIFIER.search(normalized):
        return False
    return normalized not in REVIEWED_PRERELEASES.get((group, artifact), set())

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        floor = FLOORS.get((group, artifact))
        if floor is None:
            continue
        floor_tuple, floor_text, label, line = floor
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        if parsed is not None and parsed < floor_tuple:
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} < {floor_text}")
        elif parsed is not None and not line_matches(parsed, line):
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} is outside the reviewed compatibility line")
        elif parsed is not None and has_unreviewed_qualifier(group, artifact, resolved):
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$commons_core_floor_dependencies" ]; then
    echo "Blocked Commons core dependency outside reviewed floors found in Maven POMs; keep Commons IO 2.22.0+, Compress 1.28.0+, Text 1.15.0+, Lang3 3.20.0+, Collections4 4.5.0+, BeanUtils2 2.0.0-M2+, and FileUpload2 Jakarta Servlet6 2.0.0-M5+" >&2
    echo "$commons_core_floor_dependencies" >&2
    fail=1
fi

if grep -RIn --include='pom.xml' --exclude-dir=target --exclude-dir=.git \
    -E '<artifactId>(log4j|log4j-core|log4j-api|slf4j-log4j12|reload4j)</artifactId>' .; then
    echo "Blocked direct Log4j/reload4j dependency found in Maven POMs; use SLF4J API with Logback and log4j-over-slf4j only" >&2
    fail=1
fi

if grep -RIn --include='pom.xml' --exclude-dir=target --exclude-dir=.git \
    -E '<groupId>org\.codehaus\.jackson</groupId>|<artifactId>jackson-(mapper|core|jaxrs|xc)-asl</artifactId>' .; then
    echo "Blocked legacy Codehaus Jackson 1.x dependency found in Maven POMs; use maintained Jackson 2/3 artifacts" >&2
    fail=1
fi

jackson_security_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
JACKSON2_FLOOR = (2, 22, 0)
JACKSON2_FLOOR_TEXT = "2.22.0"
JACKSON2_ANNOTATIONS_FLOOR = (2, 22, 0)
JACKSON2_ANNOTATIONS_FLOOR_TEXT = "2.22"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone|pr\d+)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

def jackson_floor(group, artifact):
    if not group.startswith("com.fasterxml.jackson.") or not artifact.startswith("jackson-"):
        return None
    if group == "com.fasterxml.jackson.core" and artifact == "jackson-annotations":
        return JACKSON2_ANNOTATIONS_FLOOR, JACKSON2_ANNOTATIONS_FLOOR_TEXT, "Jackson 2 annotations"
    return JACKSON2_FLOOR, JACKSON2_FLOOR_TEXT, "Jackson 2"

def uses_patchless_jackson2_annotations(version):
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", version.strip())
    if not match:
        return True
    major, minor, patch = match.groups()
    return not (int(major) == 2 and int(minor) >= 20 and patch is not None)

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if group.startswith("tools.jackson.") and artifact.startswith("jackson-"):
            display_version = version or "<managed>"
            failures.append(f"{pom}: Jackson 3 dependency {group}:{artifact}:{display_version} is deferred until a dedicated Jackson 3 runtime migration")
            continue
        floor = jackson_floor(group, artifact)
        if floor is None:
            continue
        floor_tuple, floor_text, label = floor
        if group == "com.fasterxml.jackson.core" and artifact == "jackson-annotations" and version == "${jackson.version}":
            failures.append(f"{pom}: Jackson 2 annotations must use ${{jackson.annotations.version}}, not ${{jackson.version}}")
            continue
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        if parsed is not None and parsed < floor_tuple:
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} < {floor_text}")
        if parsed is not None and label == "Jackson 2 annotations" and not uses_patchless_jackson2_annotations(resolved):
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: Jackson 2 annotations {display_version} uses a patch version; use the patchless 2.20+ annotations line")
        if parsed is not None and UNREVIEWED_QUALIFIER.search(resolved):
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$jackson_security_floor_dependencies" ]; then
    echo "Blocked Jackson dependency outside the maintained runtime line found in Maven POMs; keep Jackson 2 at 2.22.0+ with annotations 2.22+ and defer tools.jackson/Jackson 3 until a dedicated runtime migration" >&2
    echo "$jackson_security_floor_dependencies" >&2
    fail=1
fi

legacy_serialization_helper_dependencies=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
blocked = {
    ("com.thoughtworks.xstream", "xstream"),
    ("net.sf.json-lib", "json-lib"),
    ("net.sf.ezmorph", "ezmorph"),
    ("cglib", "cglib"),
    ("cglib", "cglib-nodep"),
    ("asm", "asm-all"),
}

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue
    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if (group, artifact) in blocked:
            failures.append(f"{pom}: {group}:{artifact}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$legacy_serialization_helper_dependencies" ]; then
    echo "Blocked legacy serialization/bytecode helper dependency found in Maven POMs; use maintained Jackson/JDK/modern ASM-family paths only after compatibility review" >&2
    echo "$legacy_serialization_helper_dependencies" >&2
    fail=1
fi

legacy_snakeyaml_dependencies=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue
    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
