JACKSON2_FLOOR = (2, 22, 0)
JACKSON3_FLOOR = (3, 1, 5)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone|pr\d+)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path:
            continue
        match = re.match(r"^(jackson-.+)-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$", jar.name)
        if not match:
            continue
        artifact, major, minor, patch, qualifier = match.groups()
        version = (int(major), int(minor), int(patch or "0"))
        if artifact == "jackson-annotations" and version[0] == 2 and version[1] >= 20 and patch is not None:
            failures.append(f"{path}: Jackson 2 annotations jar uses a patch version; use the patchless 2.20+ annotations line")
        if version[0] == 2 and version < JACKSON2_FLOOR:
            failures.append(f"{path}: Jackson 2 < 2.22.0")
        elif version[0] == 3 and version < JACKSON3_FLOOR:
            failures.append(f"{path}: Jackson 3 < 3.1.5")
        elif version[0] not in (2, 3):
            failures.append(f"{path}: unsupported Jackson major {version[0]}")
        if UNREVIEWED_QUALIFIER.search(qualifier):
            failures.append(f"{path}: Jackson jar uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$jackson_security_floor_jars" ]; then
    echo "Blocked Jackson jar below maintained stable floor packaged in app; keep Jackson 2 at 2.22.0+ and Jackson 3 at 3.1.5+ without unreviewed qualifiers" >&2
    echo "$jackson_security_floor_jars" >&2
    fail=1
fi

