db_runtime_security_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOORS = {
    "mariadb-java-client": ((3, 5, 8), "3.5.8", (3, 5)),
    "h2": ((2, 4, 240), "2.4.240", (2, 4)),
    "hsqldb": ((2, 7, 4), "2.7.4", (2, 7)),
}
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []

def parse_version(version):
    normalized = version.strip()
    if not normalized:
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path:
            continue
        for artifact, (floor_tuple, floor_text, reviewed_line) in FLOORS.items():
            match = re.match(rf"^{re.escape(artifact)}-([^/]+)\.jar$", jar.name)
            if not match:
                continue
            version_text = match.group(1)
            version = parse_version(version_text)
            if version is None:
                failures.append(f"{path}: {artifact} has an unparsable version")
            elif version[:len(reviewed_line)] != reviewed_line:
                failures.append(f"{path}: {artifact} is outside the reviewed {'.'.join(map(str, reviewed_line))}.x compatibility line")
            elif version < floor_tuple:
                failures.append(f"{path}: {artifact} < {floor_text}")
            elif UNREVIEWED_QUALIFIER.search(version_text):
                failures.append(f"{path}: {artifact} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$db_runtime_security_floor_jars" ]; then
    echo "Blocked database runtime jar outside reviewed stable lines packaged in app; keep MariaDB Connector/J 3.5.8+ on 3.5.x, H2 2.4.240+ on 2.4.x, and HSQLDB 2.7.4+ on 2.7.x" >&2
    echo "$db_runtime_security_floor_jars" >&2
    fail=1
fi

