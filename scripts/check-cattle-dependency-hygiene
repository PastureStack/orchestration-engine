actual_collection_utils_add_to_map_class_factories=$(
    git grep -l 'CollectionUtils.addToMap' -- '*.java' \
        | xargs awk '
            /CollectionUtils\.addToMap\(/ { in_call=1; start=FILENAME ":" NR ":" $0 }
            in_call && /\.class/ { print start; print FILENAME ":" NR ":" $0 }
            in_call && /;/ { in_call=0; start="" }
        ' || true
)
if [ -n "$actual_collection_utils_add_to_map_class_factories" ]; then
    echo "Blocked Class literal factories in CollectionUtils.addToMap; use ArrayList::new/HashSet::new typed suppliers" >&2
    echo "$actual_collection_utils_add_to_map_class_factories" >&2
    fail=1
fi

