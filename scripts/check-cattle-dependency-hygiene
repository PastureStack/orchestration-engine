actual_collection_utils_set_nested_suppressions=$(
    awk '
        /@SuppressWarnings\([^)]*(unchecked|rawtypes)/ { suppression_line=NR; suppression_text=$0; next }
        /setNestedValue\(/ {
            if (suppression_line && NR - suppression_line <= 2) {
                print FILENAME ":" suppression_line ":" suppression_text
            }
            suppression_line=0
        }
    ' code/framework/utils/src/main/java/io/cattle/platform/util/type/CollectionUtils.java
)
