maven_plugin_runtime_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
PLUGIN_ARTIFACT = re.compile(r"^(?:maven-.+-plugin|.+-maven-plugin)$")

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def has_plugin_ancestor(element, parent_map):
    current = element
    while current in parent_map:
        current = parent_map[current]
        if local_name(current.tag) == "plugin":
            return True
    return False

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    parent_map = {child: parent for parent in root.iter() for child in list(parent)}
    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        if has_plugin_ancestor(dep, parent_map):
            continue
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if not artifact or not PLUGIN_ARTIFACT.match(artifact):
            continue
        failures.append(f"{pom}: Maven plugin artifact {group}:{artifact} is declared as a project dependency")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_plugin_runtime_dependencies" ]; then
    echo "Blocked Maven plugin artifact declared as a project dependency; keep Maven plugins under build/pluginManagement only and out of the application dependency graph" >&2
    echo "$maven_plugin_runtime_dependencies" >&2
    fail=1
fi

junit_test_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (4, 13, 2)
FLOOR_TEXT = "4.13.2"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized:
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if group != "junit" or artifact != "junit":
            continue
        if not version:
            continue
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        display_version = version if version == resolved else f"{version}={resolved}"
        if parsed is None:
            failures.append(f"{pom}: junit:junit has unresolved or unparsable version {version!r}")
        elif parsed[0] != 4:
            failures.append(f"{pom}: junit:junit:{display_version} is outside the reviewed JUnit 4 compatibility line")
        elif parsed < FLOOR:
            failures.append(f"{pom}: junit:junit:{display_version} < {FLOOR_TEXT}")
        elif UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: junit:junit:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$junit_test_floor_dependencies" ]; then
    echo "Blocked JUnit test dependency outside reviewed stable floor found in Maven POMs; keep junit:junit 4.13.2 on the reviewed JUnit 4 line without unreviewed qualifiers until a dedicated JUnit 5 migration slice" >&2
    echo "$junit_test_floor_dependencies" >&2
    fail=1
fi

junit_test_scope_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def read_properties(root):
    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()
    return properties

def resolve_property(value, properties):
    match = re.match(r"^\$\{([^}]+)\}$", value.strip())
    if not match:
        return value
    return properties.get(match.group(1), "")

def collect_managed(root, properties):
    managed = {}
    for dep in root.findall(".//m:dependencyManagement/m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if not group or not artifact:
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        scope = (dep.findtext("m:scope", default="", namespaces=NS) or "").strip()
        managed[(group, artifact)] = {
            "version": resolve_property(version, properties) if version else "",
            "scope": scope,
        }
    return managed

def is_dependency_management_entry(dep, parent_map):
    current = dep
    while current in parent_map:
        current = parent_map[current]
        if local_name(current.tag) == "dependencyManagement":
            return True
    return False

global_root = ET.parse("code/meta-parent/pom.xml").getroot()
global_properties = read_properties(global_root)
global_managed = collect_managed(global_root, global_properties)

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(root))
    managed = dict(global_managed)
    managed.update(collect_managed(root, properties))
    parent_map = {child: parent for parent in root.iter() for child in list(parent)}

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if group != "junit" or artifact != "junit":
            continue

        explicit_version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        explicit_scope = (dep.findtext("m:scope", default="", namespaces=NS) or "").strip()
        is_managed = is_dependency_management_entry(dep, parent_map)
        if is_managed:
            version = resolve_property(explicit_version, properties) if explicit_version else ""
            scope = explicit_scope or "compile"
        else:
            managed_junit = managed.get(("junit", "junit"), {})
            version = resolve_property(explicit_version, properties) if explicit_version else managed_junit.get("version", "")
            scope = explicit_scope or managed_junit.get("scope", "") or "compile"

        if not version:
            failures.append(f"{pom}: junit:junit has no resolved managed test version")
        if scope != "test":
            failures.append(f"{pom}: junit:junit:{version or '(unresolved)'} has effective scope {scope!r}; keep JUnit test-scoped")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$junit_test_scope_dependencies" ]; then
    echo "Blocked JUnit dependency outside reviewed test scope found in Maven POMs; keep junit:junit managed and direct usage test-scoped so JUnit cannot become runtime payload" >&2
    echo "$junit_test_scope_dependencies" >&2
    fail=1
fi

hamcrest_test_scope_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (3, 0, 0)
FLOOR_TEXT = "3.0"
LINE = (3,)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def read_properties(pom):
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError:
        return {}
    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()
    return properties

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:\.(\d+))?([-.].*)?$", normalized)
    if not match:
        return None
    major, minor, patch, _suffix = match.groups()
    return (int(major), int(minor), int(patch or "0"))

global_properties = read_properties(Path("code/meta-parent/pom.xml"))
failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(pom))

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if group != "org.hamcrest":
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if not version:
            continue
        scope = (dep.findtext("m:scope", default="", namespaces=NS) or "").strip()
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        display_version = version if version == resolved else f"{version}={resolved}"
        label = f"org.hamcrest:{artifact}:{display_version}"
        if scope != "test":
            failures.append(f"{pom}: Hamcrest {label} is not test-scoped")
        elif parsed is None:
            failures.append(f"{pom}: Hamcrest {label} is not a concrete reviewed version")
        elif parsed[:len(LINE)] != LINE:
            failures.append(f"{pom}: Hamcrest {label} is outside the reviewed 3.x test compatibility line")
        elif parsed < FLOOR:
            failures.append(f"{pom}: Hamcrest {label} < {FLOOR_TEXT}")
        elif UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: Hamcrest {label} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$hamcrest_test_scope_dependencies" ]; then
    echo "Blocked Hamcrest test dependency outside reviewed test scope/floor found in Maven POMs; keep direct org.hamcrest dependencies test-scoped on stable 3.x at 3.0+ without unreviewed qualifiers" >&2
    echo "$hamcrest_test_scope_dependencies" >&2
    fail=1
fi

jooq_runtime_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOORS = {
    ("org.jooq", "jooq"): ((3, 21, 5), "3.21.5", "jOOQ runtime", (3, 21)),
    ("org.jooq", "jooq-meta"): ((3, 21, 5), "3.21.5", "jOOQ metadata", (3, 21)),
    ("org.jooq", "jooq-codegen"): ((3, 21, 5), "3.21.5", "jOOQ codegen", (3, 21)),
    ("org.jooq", "jooq-jpa-extensions"): ((3, 21, 5), "3.21.5", "jOOQ JPA extensions", (3, 21)),
}
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

def line_matches(parsed, line):
    return parsed[:len(line)] == line

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            name = local_name(child.tag)
            value = (child.text or "").strip()
            properties[name] = value
            if name == "jooq.version":
                parsed = parse_version(value)
                if parsed is None:
                    continue
                if not line_matches(parsed, (3, 21)):
                    failures.append(f"{pom}: jOOQ property jooq.version={value} is outside the reviewed 3.21.x compatibility line")
                elif parsed < (3, 21, 5):
                    failures.append(f"{pom}: jOOQ property jooq.version={value} < 3.21.5")
                elif UNREVIEWED_QUALIFIER.search(value):
                    failures.append(f"{pom}: jOOQ property jooq.version={value} uses an unreviewed qualifier")

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        floor = FLOORS.get((group, artifact))
        if floor is None:
            continue
        floor_tuple, floor_text, label, line = floor
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        if parsed is None:
            continue
        display_version = version if version == resolved else f"{version}={resolved}"
        if not line_matches(parsed, line):
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} is outside the reviewed 3.21.x compatibility line")
        elif parsed < floor_tuple:
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} < {floor_text}")
        elif UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: {label} {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
