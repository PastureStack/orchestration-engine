maven_bom_import_dependencies=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def is_dependency_management_entry(dep, parent_map):
    current = dep
    while current in parent_map:
        current = parent_map[current]
        if local_name(current.tag) == "dependencyManagement":
            return True
    return False

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    parent_map = {child: parent for parent in root.iter() for child in list(parent)}
    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        if not is_dependency_management_entry(dep, parent_map):
            continue
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        dep_type = (dep.findtext("m:type", default="", namespaces=NS) or "").strip()
        scope = (dep.findtext("m:scope", default="", namespaces=NS) or "").strip()
        if scope == "import" or (dep_type == "pom" and (artifact.endswith("-bom") or artifact.endswith("-dependencies"))):
            label = f"{group}:{artifact}:{version or '(unresolved)'}"
            failures.append(f"{pom}: dependencyManagement BOM/import entry {label} has type {dep_type or '(default)'} and scope {scope or '(default)'}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_bom_import_dependencies" ]; then
    echo "Blocked Maven BOM/import dependencyManagement entry; keep dependency versions explicitly pinned by reviewed artifact guards until a dedicated BOM compatibility slice proves the imported line cannot rewrite runtime, test, or plugin surfaces" >&2
    echo "$maven_bom_import_dependencies" >&2
    fail=1
fi

maven_dynamic_external_versions=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
DYNAMIC_TOKEN = re.compile(r"(?i)(?:^|[.-])snapshot(?:[.-]|$)|^(?:latest|release)$")

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def read_properties(root):
    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()
    return properties

def resolve_property(value, properties):
    match = re.match(r"^\$\{([^}]+)\}$", value.strip())
    if not match:
        return value
    return properties.get(match.group(1), "")

def is_dynamic_version(value):
    normalized = value.strip()
    return normalized.startswith(("[", "(")) or bool(DYNAMIC_TOKEN.search(normalized))

def display_version(raw, resolved):
    return raw if raw == resolved else f"{raw}={resolved}"

def is_internal_group(group):
    return group == "io.cattle" or group.startswith("io.cattle.")

try:
    global_root = ET.parse("code/meta-parent/pom.xml").getroot()
    global_properties = read_properties(global_root)
except (FileNotFoundError, ET.ParseError):
    global_properties = {}

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(root))

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        raw_version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if not group or not artifact or not raw_version or is_internal_group(group):
            continue
        resolved = resolve_property(raw_version, properties)
        if resolved and is_dynamic_version(resolved):
            failures.append(f"{pom}: external dependency {group}:{artifact}:{display_version(raw_version, resolved)} uses a dynamic version")

    for plugin in root.findall(".//m:build//m:plugins/m:plugin", NS):
        group = (plugin.findtext("m:groupId", default="org.apache.maven.plugins", namespaces=NS) or "org.apache.maven.plugins").strip()
        artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        raw_version = (plugin.findtext("m:version", default="", namespaces=NS) or "").strip()
        if not artifact or not raw_version or is_internal_group(group):
            continue
        resolved = resolve_property(raw_version, properties)
        if resolved and is_dynamic_version(resolved):
            failures.append(f"{pom}: Maven plugin {group}:{artifact}:{display_version(raw_version, resolved)} uses a dynamic version")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_dynamic_external_versions" ]; then
    echo "Blocked dynamic external Maven versions; keep external dependencies and build plugins on explicit reviewed versions instead of LATEST, RELEASE, SNAPSHOT, or version ranges" >&2
    echo "$maven_dynamic_external_versions" >&2
    fail=1
fi

