from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
DEFAULT_PLUGIN_GROUP = "org.apache.maven.plugins"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)
FLOORS = {
    ("org.apache.maven.plugins", "maven-enforcer-plugin"): ((3, 6, 3), "3.6.3", "Maven 3.x plugin line"),
    ("org.apache.maven.plugins", "maven-compiler-plugin"): ((3, 15, 0), "3.15.0", "Maven 3.x plugin line"),
