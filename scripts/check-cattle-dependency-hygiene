bouncycastle_jdk18on_security_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (1, 84, 0)
FLOOR_TEXT = "1.84"
REVIEWED_LINE = (1,)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if group != "org.bouncycastle" or not artifact.endswith("-jdk18on"):
            continue
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        if parsed is not None and parsed[:len(REVIEWED_LINE)] != REVIEWED_LINE:
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {group}:{artifact}:{display_version} is outside the reviewed BC-JAVA 1.x compatibility line")
        elif parsed is not None and parsed < FLOOR:
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {group}:{artifact}:{display_version} < {FLOOR_TEXT}")
        elif parsed is not None and UNREVIEWED_QUALIFIER.search(resolved):
            display_version = version if version == resolved else f"{version}={resolved}"
            failures.append(f"{pom}: {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$bouncycastle_jdk18on_security_floor_dependencies" ]; then
    echo "Blocked Bouncy Castle jdk18on dependency outside the reviewed stable line found in Maven POMs; keep BC-JAVA 1.84+ on the reviewed 1.x line for current CVE fixes" >&2
    echo "$bouncycastle_jdk18on_security_floor_dependencies" >&2
    fail=1
fi

liquibase_core_security_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (5, 0, 3)
FLOOR_TEXT = "5.0.3"
REVIEWED_LINE = (5,)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
