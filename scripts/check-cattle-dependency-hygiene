    return "".join(element.itertext()).strip()

def compiler_arg_texts(configuration):
    for arg in configuration.findall("m:compilerArgs/m:arg", NS):
        value = text(arg)
        if value:
            yield "compilerArgs/arg", value
    for container in configuration.findall("m:compilerArgs", NS):
        value = text(container)
        if value:
            yield "compilerArgs", value
    for container in configuration.findall("m:compilerArgument", NS):
        value = text(container)
