commons_core_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOORS = {
    "commons-io": ((2, 22, 0, 999), "2.22.0", (2,), re.compile(r"^commons-io-([^/]+)\.jar$")),
    "commons-compress": ((1, 28, 0, 999), "1.28.0", (1,), re.compile(r"^commons-compress-([^/]+)\.jar$")),
    "commons-text": ((1, 15, 0, 999), "1.15.0", (1,), re.compile(r"^commons-text-([^/]+)\.jar$")),
    "commons-lang3": ((3, 20, 0, 999), "3.20.0", (3,), re.compile(r"^commons-lang3-([^/]+)\.jar$")),
    "commons-collections4": ((4, 5, 0, 999), "4.5.0", (4,), re.compile(r"^commons-collections4-([^/]+)\.jar$")),
    "commons-beanutils2": ((2, 0, 0, 2), "2.0.0-M2", (2,), re.compile(r"^commons-beanutils2-([^/]+)\.jar$")),
    "commons-fileupload2-jakarta-servlet6": ((2, 0, 0, 5), "2.0.0-M5", (2,), re.compile(r"^commons-fileupload2-jakarta-servlet6-([^/]+)\.jar$")),
}
REVIEWED_PRERELEASES = {
    "commons-beanutils2": {"2.0.0-M2"},
    "commons-fileupload2-jakarta-servlet6": {"2.0.0-M5"},
}
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []

def parse_version(version):
    normalized = version.strip()
    if not normalized:
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:-M(\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch, milestone = match.groups()
    return (int(major), int(minor), int(patch or "0"), int(milestone or "999"))

def line_matches(version, line):
    return version[:len(line)] == line

def has_unreviewed_qualifier(artifact, version):
    normalized = version.strip()
    if not UNREVIEWED_QUALIFIER.search(normalized):
        return False
    return normalized not in REVIEWED_PRERELEASES.get(artifact, set())

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path and "/WEB-INF/jetty/" not in path:
            continue
        for artifact, (floor_tuple, floor_text, line, pattern) in FLOORS.items():
            match = pattern.match(jar.name)
            if not match:
                continue
            version_text = match.group(1)
            version = parse_version(version_text)
            if version is None:
                failures.append(f"{path}: {artifact} has an unparsable version")
                continue
            if not line_matches(version, line):
                failures.append(f"{path}: {artifact} is outside the reviewed compatibility line")
            elif version < floor_tuple:
                failures.append(f"{path}: {artifact} < {floor_text}")
            elif has_unreviewed_qualifier(artifact, version_text):
                failures.append(f"{path}: {artifact} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
