    "jakarta.inject-api": ((2, 0, 1), "2.0.1", (2, 0), re.compile(r"^jakarta\.inject-api-(\d+)\.(\d+)\.(\d+)([^/]*)\.jar$")),
    "jakarta.persistence-api": ((3, 2, 0), "3.2.0", (3, 2), re.compile(r"^jakarta\.persistence-api-(\d+)\.(\d+)\.(\d+)([^/]*)\.jar$")),
    "jakarta.servlet-api": ((6, 1, 0), "6.1.0", (6, 1), re.compile(r"^jakarta\.servlet-api-(\d+)\.(\d+)\.(\d+)([^/]*)\.jar$")),
    "jakarta.xml.bind-api": ((4, 0, 5), "4.0.5", (4, 0), re.compile(r"^jakarta\.xml\.bind-api-(\d+)\.(\d+)\.(\d+)([^/]*)\.jar$")),
