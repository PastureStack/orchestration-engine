root = Path("code/packaging/app/target")
failures = []
jar_pattern = re.compile(r"^(docker-java(?:-[A-Za-z0-9]+)*)-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")

if root.exists():
