runtime_framework_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path
import os

SPRING_FLOOR = (6, 2, 18)
SPRING_LINE = (6, 2)
SPRING7_EVALUATION_FLOOR = (7, 0, 7)
SPRING7_EVALUATION_LINE = (7, 0)
JETTY_FLOOR = (12, 1, 10)
JETTY_LINE = (12, 1)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)
ALLOW_SPRING7_EVALUATION = os.environ.get("RC16_ALLOW_SPRING7_EVALUATION") == "1"
root = Path("code/packaging/app/target")
failures = []

def parse_spring_version(name):
    match = re.match(r"^spring-[^-]+(?:-[^-]+)*?-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$", name)
    if not match:
        return None
    major, minor, patch, qualifier = match.groups()
    return (int(major), int(minor), int(patch or "0")), qualifier

def parse_jetty_version(name):
    match = re.match(r"^jetty-[^-]+(?:-[^-]+)*?-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$", name)
    if not match:
        return None
    major, minor, patch, qualifier = match.groups()
    return (int(major), int(minor), int(patch or "0")), qualifier

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path and "/WEB-INF/jetty/" not in path:
            continue
        spring_result = parse_spring_version(jar.name)
        if spring_result is not None:
            spring_version, qualifier = spring_result
            if spring_version[0] < 6:
                failures.append(f"{path}: Spring jar is below Spring 6")
            elif ALLOW_SPRING7_EVALUATION and spring_version[:len(SPRING7_EVALUATION_LINE)] == SPRING7_EVALUATION_LINE:
                if spring_version < SPRING7_EVALUATION_FLOOR:
                    failures.append(f"{path}: Spring jar < 7.0.7 evaluation floor")
                elif UNREVIEWED_QUALIFIER.search(qualifier):
                    failures.append(f"{path}: Spring jar uses an unreviewed qualifier")
            elif spring_version[0] == 7:
                if not ALLOW_SPRING7_EVALUATION:
                    failures.append(f"{path}: Spring jar is Spring 7; set RC16_ALLOW_SPRING7_EVALUATION=1 for the reviewed 7.0.x evaluation line")
                else:
                    failures.append(f"{path}: Spring jar is outside the reviewed 7.0.x evaluation line")
            elif spring_version[:len(SPRING_LINE)] != SPRING_LINE:
                failures.append(f"{path}: Spring jar is outside the reviewed 6.2.x compatibility line")
            elif spring_version < SPRING_FLOOR:
                failures.append(f"{path}: Spring jar < 6.2.18")
            elif UNREVIEWED_QUALIFIER.search(qualifier):
                failures.append(f"{path}: Spring jar uses an unreviewed qualifier")
            continue
        if re.match(r"^spring-[^-]+(?:-[^-]+)*-[1-5]\.", jar.name):
            failures.append(f"{path}: Spring jar is below Spring 6")
            continue
        if not jar.name.startswith("jetty-"):
            continue
        jetty_result = parse_jetty_version(jar.name)
        if jetty_result is None:
            continue
        version, qualifier = jetty_result
        if version[0] < 12:
            failures.append(f"{path}: Jetty jar is below Jetty 12")
        elif version[:len(JETTY_LINE)] != JETTY_LINE:
            failures.append(f"{path}: Jetty jar is outside the reviewed 12.1.x compatibility line")
        elif version < JETTY_FLOOR:
            failures.append(f"{path}: Jetty jar < 12.1.10")
        elif UNREVIEWED_QUALIFIER.search(qualifier):
            failures.append(f"{path}: Jetty jar uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$runtime_framework_floor_jars" ]; then
