    echo "$maven_javadoc_reporting_configs" >&2
    fail=1
fi

maven_toolchain_floor_configs=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
EXPECTED_POM = Path("code/meta-parent/pom.xml")
EXPECTED_ENFORCER_PLUGIN = ("org.apache.maven.plugins", "maven-enforcer-plugin")
EXPECTED_JAVA_RELEASE = "25"
EXPECTED_MAVEN_RANGE = "[3.9.14,)"
EXPECTED_JAVA_RANGE = "[25,26)"
BLOCKED_COMPILER_VERSION_PROPERTIES = {
    "maven.compiler.release",
    "maven.compiler.source",
    "maven.compiler.target",
}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def plugin_key(plugin):
    group = (plugin.findtext("m:groupId", default="org.apache.maven.plugins", namespaces=NS) or "org.apache.maven.plugins").strip()
    artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
    return group, artifact

def text(element):
    return "".join(element.itertext()).strip()

def direct_child_text(element, child_name):
    child = element.find(f"m:{child_name}", NS)
    return (child.text or "").strip() if child is not None else ""

failures = []
seen_release_property = False
seen_toolchain_execution = False

for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for properties in root.findall(".//m:properties", NS):
        for prop in list(properties):
            name = local_name(prop.tag)
            value = text(prop)
            if name == "java.compiler.release":
                if pom == EXPECTED_POM and value == EXPECTED_JAVA_RELEASE:
                    seen_release_property = True
                else:
                    failures.append(f"{pom}: java.compiler.release changed from reviewed JDK {EXPECTED_JAVA_RELEASE} to {value or '(missing)'}")
            if name in BLOCKED_COMPILER_VERSION_PROPERTIES:
                failures.append(f"{pom}: Maven compiler version override <{name}> bypasses the reviewed java.compiler.release property")

    for plugin in root.findall(".//m:plugin", NS):
        if plugin_key(plugin) != EXPECTED_ENFORCER_PLUGIN:
            continue

        if pom != EXPECTED_POM:
            failures.append(f"{pom}: unreviewed Maven Enforcer configuration can rewrite the JDK25/Maven toolchain gate")
            continue

        for execution in plugin.findall("m:executions/m:execution", NS):
            execution_id = direct_child_text(execution, "id")
            phase = direct_child_text(execution, "phase")
            goals = tuple(
                (goal.text or "").strip()
                for goal in execution.findall("m:goals/m:goal", NS)
                if (goal.text or "").strip()
            )
            require_maven = execution.find("m:configuration/m:rules/m:requireMavenVersion", NS)
            require_java = execution.find("m:configuration/m:rules/m:requireJavaVersion", NS)
            if execution_id != "enforce-jdk25-toolchain":
                continue
            seen_toolchain_execution = True
            if phase != "validate":
                failures.append(f"{pom}: enforce-jdk25-toolchain must stay bound to validate phase, got {phase or '(missing)'}")
            if goals != ("enforce",):
                failures.append(f"{pom}: enforce-jdk25-toolchain goals changed from enforce to {', '.join(goals) or '(missing)'}")
            maven_range = (require_maven.findtext("m:version", default="", namespaces=NS) if require_maven is not None else "").strip()
            java_range = (require_java.findtext("m:version", default="", namespaces=NS) if require_java is not None else "").strip()
            if maven_range != EXPECTED_MAVEN_RANGE:
                failures.append(f"{pom}: requireMavenVersion changed from {EXPECTED_MAVEN_RANGE} to {maven_range or '(missing)'}")
            if java_range != EXPECTED_JAVA_RANGE:
                failures.append(f"{pom}: requireJavaVersion changed from {EXPECTED_JAVA_RANGE} to {java_range or '(missing)'}")

if not seen_release_property:
    failures.append(f"{EXPECTED_POM}: reviewed java.compiler.release={EXPECTED_JAVA_RELEASE} property is missing")
if not seen_toolchain_execution:
    failures.append(f"{EXPECTED_POM}: reviewed enforce-jdk25-toolchain Enforcer execution is missing")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_toolchain_floor_configs" ]; then
    echo "Blocked Maven/JDK toolchain floor drift; keep java.compiler.release, Maven Enforcer phase/goals, requireMavenVersion, and requireJavaVersion pinned to the reviewed JDK25 toolchain gate" >&2
    echo "$maven_toolchain_floor_configs" >&2
    fail=1
fi

maven_compiler_warning_configs=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
COMPILER_PLUGIN = ("org.apache.maven.plugins", "maven-compiler-plugin")
EXPECTED_COMPILER = (
    Path("code/meta-parent/pom.xml"),
    "${java.compiler.release}",
    ("-Xlint:deprecation", "-Xlint:removal", "-Xlint:unchecked"),
)
BLOCKED_PROPERTIES = {
    "maven.compiler.failOnWarning": "false",
    "maven.compiler.showDeprecation": "false",
    "maven.compiler.showWarnings": "false",
    "maven.compiler.skip": "true",
}
BLOCKED_ANY_PROPERTIES = {
    "maven.compiler.compilerArgument",
    "maven.compiler.compilerArgs",
    "maven.compiler.proc",
}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def plugin_key(plugin):
    group = (plugin.findtext("m:groupId", default="org.apache.maven.plugins", namespaces=NS) or "org.apache.maven.plugins").strip()
    artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
    return group, artifact

def text(element):
    return "".join(element.itertext()).strip()

failures = []
seen_expected = False

for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for properties in root.findall(".//m:properties", NS):
        for prop in list(properties):
            name = local_name(prop.tag)
            value = text(prop).lower()
            if name in BLOCKED_ANY_PROPERTIES:
                failures.append(f"{pom}: Maven compiler warning surface property <{name}> is declared outside the reviewed compiler plugin configuration")
            if name in BLOCKED_PROPERTIES and value == BLOCKED_PROPERTIES[name]:
                failures.append(f"{pom}: Maven compiler warning surface property <{name}>{text(prop)}</{name}> weakens JDK25 warning visibility")

    for plugin in root.findall(".//m:plugin", NS):
        if plugin_key(plugin) != COMPILER_PLUGIN:
            continue

        configuration = plugin.find("m:configuration", NS)
        if configuration is None:
            failures.append(f"{pom}: Maven compiler plugin is missing reviewed JDK25 warning configuration")
            continue

        release = (configuration.findtext("m:release", default="", namespaces=NS) or "").strip()
        show_warnings = (configuration.findtext("m:showWarnings", default="", namespaces=NS) or "").strip().lower()
        show_deprecation = (configuration.findtext("m:showDeprecation", default="", namespaces=NS) or "").strip().lower()
        fail_on_error = (configuration.findtext("m:failOnError", default="", namespaces=NS) or "").strip().lower()
        skip_main = (configuration.findtext("m:skipMain", default="", namespaces=NS) or "").strip().lower()
        nowarn = (configuration.findtext("m:nowarn", default="", namespaces=NS) or "").strip().lower()
        proc = (configuration.findtext("m:proc", default="", namespaces=NS) or "").strip().lower()
        compiler_args = tuple(
            (arg.text or "").strip()
            for arg in configuration.findall("m:compilerArgs/m:arg", NS)
            if (arg.text or "").strip()
        )

        if pom == EXPECTED_COMPILER[0]:
            seen_expected = True
            expected_release, expected_args = EXPECTED_COMPILER[1], EXPECTED_COMPILER[2]
            if release != expected_release:
                failures.append(f"{pom}: reviewed Maven compiler release changed from {expected_release} to {release or '(missing)'}")
            if show_warnings != "true":
                failures.append(f"{pom}: reviewed Maven compiler showWarnings must stay true")
            if show_deprecation != "true":
                failures.append(f"{pom}: reviewed Maven compiler showDeprecation must stay true")
            missing_args = [arg for arg in expected_args if arg not in compiler_args]
            if missing_args:
                failures.append(f"{pom}: reviewed Maven compilerArgs missing {', '.join(missing_args)}")
        else:
            failures.append(f"{pom}: unreviewed Maven compiler plugin configuration can rewrite the JDK25 warning surface")

        if fail_on_error == "false":
            failures.append(f"{pom}: Maven compiler plugin weakens compile failure handling with <failOnError>false</failOnError>")
        if skip_main == "true":
            failures.append(f"{pom}: Maven compiler plugin skips main compilation with <skipMain>true</skipMain>")
        if nowarn == "true":
            failures.append(f"{pom}: Maven compiler plugin disables warnings with <nowarn>true</nowarn>")
        if proc == "none":
            failures.append(f"{pom}: Maven compiler plugin disables annotation processing with <proc>none</proc> without a dedicated compatibility slice")

if not seen_expected:
    failures.append("code/meta-parent/pom.xml: reviewed Maven compiler plugin configuration is missing")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_compiler_warning_configs" ]; then
    echo "Blocked Maven compiler warning configuration drift; keep the reviewed JDK25 release, warning visibility, deprecation visibility, and Xlint arguments active unless a dedicated compiler compatibility slice validates the change" >&2
    echo "$maven_compiler_warning_configs" >&2
    fail=1
fi

