maven_resolution_repositories=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}

def repo_enabled(repo, section):
    policy = repo.find(f"m:{section}", NS)
    if policy is None:
        return "default"
    enabled = (policy.findtext("m:enabled", default="", namespaces=NS) or "").strip()
    return enabled or "default"

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for repositories in root.findall(".//m:repositories", NS):
        for repo in repositories.findall("m:repository", NS):
            repo_id = (repo.findtext("m:id", default="", namespaces=NS) or "").strip()
            url = (repo.findtext("m:url", default="", namespaces=NS) or "").strip()
            releases = repo_enabled(repo, "releases")
            snapshots = repo_enabled(repo, "snapshots")
            failures.append(f"{pom}: Maven dependency repository {repo_id or '(no id)'} url {url or '(no url)'} releases={releases} snapshots={snapshots}")

    for repositories in root.findall(".//m:pluginRepositories", NS):
        for repo in repositories.findall("m:pluginRepository", NS):
            repo_id = (repo.findtext("m:id", default="", namespaces=NS) or "").strip()
            url = (repo.findtext("m:url", default="", namespaces=NS) or "").strip()
            releases = repo_enabled(repo, "releases")
            snapshots = repo_enabled(repo, "snapshots")
            failures.append(f"{pom}: Maven plugin repository {repo_id or '(no id)'} url {url or '(no url)'} releases={releases} snapshots={snapshots}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_resolution_repositories" ]; then
    echo "Blocked Maven dependency/plugin repository override in POMs; keep artifact resolution on the reviewed default repository path unless a dedicated supply-chain compatibility slice validates additional repositories and snapshot policy" >&2
    echo "$maven_resolution_repositories" >&2
    fail=1
fi

maven_build_extensions=$(
    python3 - <<'PY'
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    parent_map = {child: parent for parent in root.iter() for child in list(parent)}
    for extension in root.findall(".//m:extensions/m:extension", NS):
        parent = parent_map.get(extension)
        grandparent = parent_map.get(parent)
        if parent is None or grandparent is None or local_name(parent.tag) != "extensions" or local_name(grandparent.tag) != "build":
            continue
        group = (extension.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (extension.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (extension.findtext("m:version", default="", namespaces=NS) or "").strip()
        failures.append(f"{pom}: Maven build extension {group}:{artifact}:{version or '(unresolved)'} is added to the running build classpath")

    for plugin in root.findall(".//m:build//m:plugins/m:plugin", NS):
        extension_enabled = (plugin.findtext("m:extensions", default="", namespaces=NS) or "").strip().lower()
        if extension_enabled != "true":
            continue
        group = (plugin.findtext("m:groupId", default="org.apache.maven.plugins", namespaces=NS) or "org.apache.maven.plugins").strip()
        artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (plugin.findtext("m:version", default="", namespaces=NS) or "").strip()
        failures.append(f"{pom}: Maven plugin {group}:{artifact}:{version or '(unresolved)'} enables build extensions")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$maven_build_extensions" ]; then
    echo "Blocked Maven build extension surface; keep artifacts out of the running Maven build classpath unless a dedicated build-lifecycle compatibility slice validates the extension and its dependency graph" >&2
    echo "$maven_build_extensions" >&2
    fail=1
fi

