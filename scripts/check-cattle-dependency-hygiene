guava_stable_line_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOOR = (33, 6, 0)
FLOOR_TEXT = "33.6.0-jre"
LINE = (33,)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []
pattern = re.compile(r"^guava-(\d+)\.(\d+)(?:\.(\d+))?([-.][^/]*)?\.jar$")

if root.exists():
    for jar in sorted(root.glob("*/WEB-INF/lib/guava-*.jar")):
        match = pattern.match(jar.name)
        if not match:
            continue
        major, minor, patch, suffix = match.groups()
        version = (int(major), int(minor), int(patch or "0"))
        suffix = suffix or ""
        if version[:len(LINE)] != LINE:
            failures.append(f"{jar}: Guava is outside the reviewed 33.x JRE compatibility line")
        elif version < FLOOR:
            failures.append(f"{jar}: Guava < {FLOOR_TEXT}")
        elif UNREVIEWED_QUALIFIER.search(suffix):
            failures.append(f"{jar}: Guava uses an unreviewed qualifier")
        elif suffix != "-jre":
            failures.append(f"{jar}: Guava is not on the reviewed JRE artifact line")

print("\n".join(failures))
sys.exit(0)
PY
)
