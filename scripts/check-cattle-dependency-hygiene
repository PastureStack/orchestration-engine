    ("org.codehaus.mojo", "buildnumber-maven-plugin"): ((3, 3, 0), "3.3.0", "MojoHaus 3.x plugin line"),
}

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    for plugin in root.findall(".//m:build//m:plugins/m:plugin", NS):
        group = (plugin.findtext("m:groupId", default="", namespaces=NS) or DEFAULT_PLUGIN_GROUP).strip()
        artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        key = (group, artifact)
        if key not in FLOORS:
            continue
        version = (plugin.findtext("m:version", default="", namespaces=NS) or "").strip()
        parsed = parse_version(version)
        if parsed is None:
            failures.append(f"{pom}: {group}:{artifact} has unresolved or unparsable version {version!r}")
            continue
        floor, floor_text, line_text = FLOORS[key]
        if parsed[0] != 3:
            failures.append(f"{pom}: {group}:{artifact}:{version} is outside the reviewed {line_text}")
        elif parsed < floor:
            failures.append(f"{pom}: {group}:{artifact}:{version} < {floor_text}")
        elif UNREVIEWED_QUALIFIER.search(version):
            failures.append(f"{pom}: {group}:{artifact}:{version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
