        return version
    return properties.get(match.group(1), "")

global_properties = read_properties(Path("code/meta-parent/pom.xml"))
failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(pom))

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if group != "com.hazelcast":
            continue
        if artifact == "hazelcast-client":
            failures.append(f"{pom}: retired com.hazelcast:hazelcast-client dependency is not available on the reviewed Hazelcast 5.x line")
            continue
        if artifact != "hazelcast":
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        display_version = version if version == resolved else f"{version}={resolved}"
        if parsed is not None and parsed < FLOOR:
            failures.append(f"{pom}: hazelcast {group}:{artifact}:{display_version} < {FLOOR_TEXT}")
        elif parsed is not None and parsed[:2] != (5, 7):
            failures.append(f"{pom}: hazelcast {group}:{artifact}:{display_version} is outside the reviewed 5.7.x compatibility line")
        elif parsed is not None and UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: hazelcast {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$hazelcast_floor_dependencies" ]; then
    echo "Blocked Hazelcast dependency outside reviewed stable floor found in Maven POMs; keep com.hazelcast:hazelcast 5.7.0+ on the reviewed 5.7.x Java 25 line without unreviewed qualifiers" >&2
    echo "$hazelcast_floor_dependencies" >&2
    fail=1
fi

hazelcast_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOOR = (5, 7, 0)
FLOOR_TEXT = "5.7.0"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []
core_pattern = re.compile(r"^hazelcast-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")
client_pattern = re.compile(r"^hazelcast-client-.*\.jar$")

if root.exists():
    for jar in sorted(root.glob("*/WEB-INF/lib/hazelcast-*.jar")):
        if client_pattern.match(jar.name):
            failures.append(f"{jar}: retired hazelcast-client jar packaged; use reviewed Hazelcast 5.x integration instead")
            continue
        match = core_pattern.match(jar.name)
        if not match:
            continue
        major, minor, patch, qualifier = match.groups()
        parsed = (int(major), int(minor), int(patch or "0"))
        if parsed < FLOOR:
            failures.append(f"{jar}: hazelcast {'.'.join(map(str, parsed))} < {FLOOR_TEXT}")
        elif parsed[:2] != (5, 7):
            failures.append(f"{jar}: hazelcast {'.'.join(map(str, parsed))} is outside the reviewed 5.7.x compatibility line")
        elif UNREVIEWED_QUALIFIER.search(qualifier):
            failures.append(f"{jar}: hazelcast uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$hazelcast_floor_jars" ]; then
    echo "Blocked Hazelcast jar outside reviewed stable floor packaged in app; keep com.hazelcast:hazelcast 5.7.0+ on the reviewed 5.7.x Java 25 line without unreviewed qualifiers" >&2
    echo "$hazelcast_floor_jars" >&2
    fail=1
fi

