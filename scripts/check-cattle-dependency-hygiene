legacy_guava_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def starts_legacy_guava(version):
    normalized = version.strip()
    if not normalized:
        return False
    if normalized.startswith("${"):
        return False
    if normalized.startswith("r"):
        return True
    match = re.match(r"^(\d+)(?:[.-]|$)", normalized)
    return bool(match and int(match.group(1)) <= 31)

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    legacy_properties = set()
    properties = root.find("m:properties", NS)
    if properties is not None:
        for child in list(properties):
            name = local_name(child.tag)
            value = (child.text or "").strip()
            if name == "guava.version" and starts_legacy_guava(value):
                failures.append(f"{pom}: guava.version={value}")
                legacy_properties.add(name)

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if group == "com.google.collections":
            failures.append(f"{pom}: {group}:{artifact}")
        if group == "com.google.guava" and artifact == "guava-jdk5":
            failures.append(f"{pom}: {group}:{artifact}")
        if group == "com.google.guava" and artifact == "guava":
            if starts_legacy_guava(version) or version == "${guava.version}" and "guava.version" in legacy_properties:
                failures.append(f"{pom}: {group}:{artifact}:{version}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$legacy_guava_dependencies" ]; then
    echo "Blocked legacy Google Collections/Guava dependency found in Maven POMs; keep Guava 32+ on the maintained JDK line" >&2
    echo "$legacy_guava_dependencies" >&2
    fail=1
fi

guava_stable_line_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (33, 6, 0)
FLOOR_TEXT = "33.6.0-jre"
LINE = (33,)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def read_properties(pom):
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError:
        return {}
    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()
    return properties

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

def parse_guava_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None, ""
    match = re.match(r"^(\d+)\.(\d+)(?:\.(\d+))?([-.].*)?$", normalized)
    if not match:
        return None, ""
    major, minor, patch, suffix = match.groups()
    return (int(major), int(minor), int(patch or "0")), (suffix or "")

global_properties = read_properties(Path("code/meta-parent/pom.xml"))
failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(pom))

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if group != "com.google.guava" or artifact != "guava":
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if not version:
            continue
        resolved = resolve_property(version, properties)
        parsed, suffix = parse_guava_version(resolved)
        display_version = version if version == resolved else f"{version}={resolved}"
        if parsed is None:
            failures.append(f"{pom}: Guava com.google.guava:guava:{display_version} is not a concrete reviewed version")
        elif parsed[:len(LINE)] != LINE:
            failures.append(f"{pom}: Guava com.google.guava:guava:{display_version} is outside the reviewed 33.x JRE compatibility line")
        elif parsed < FLOOR:
            failures.append(f"{pom}: Guava com.google.guava:guava:{display_version} < {FLOOR_TEXT}")
        elif UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: Guava com.google.guava:guava:{display_version} uses an unreviewed qualifier")
        elif suffix != "-jre":
            failures.append(f"{pom}: Guava com.google.guava:guava:{display_version} is not on the reviewed JRE artifact line")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$guava_stable_line_dependencies" ]; then
    echo "Blocked Guava dependency outside the reviewed stable JRE line found in Maven POMs; keep Guava on stable 33.x at 33.6.0-jre+ without unreviewed qualifiers" >&2
    echo "$guava_stable_line_dependencies" >&2
    fail=1
fi

runtime_framework_floor_versions=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path
import os

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
SPRING_FLOOR = (6, 2, 18)
SPRING_FLOOR_TEXT = "6.2.18"
SPRING_LINE = (6, 2)
SPRING7_EVALUATION_FLOOR = (7, 0, 7)
SPRING7_EVALUATION_FLOOR_TEXT = "7.0.7"
SPRING7_EVALUATION_LINE = (7, 0)
JETTY_FLOOR = (12, 1, 10)
JETTY_FLOOR_TEXT = "12.1.10"
JETTY_LINE = (12, 1)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)
ALLOW_SPRING7_EVALUATION = os.environ.get("RC16_ALLOW_SPRING7_EVALUATION") == "1"

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

def spring_failure(label, version):
    parsed = parse_version(version)
    if parsed is None:
        return None
    if parsed[0] < 6:
        return f"{label}={version} is below Spring 6"
    if ALLOW_SPRING7_EVALUATION and parsed[:len(SPRING7_EVALUATION_LINE)] == SPRING7_EVALUATION_LINE:
        if parsed < SPRING7_EVALUATION_FLOOR:
            return f"{label}={version} < Spring 7 evaluation floor {SPRING7_EVALUATION_FLOOR_TEXT}"
        if UNREVIEWED_QUALIFIER.search(version):
            return f"{label}={version} uses an unreviewed qualifier"
        return None
    if parsed[0] == 7:
        if not ALLOW_SPRING7_EVALUATION:
            return f"{label}={version} is Spring 7; set RC16_ALLOW_SPRING7_EVALUATION=1 for the reviewed 7.0.x evaluation line"
        return f"{label}={version} is outside the reviewed Spring 7.0.x evaluation line"
    if parsed[:len(SPRING_LINE)] != SPRING_LINE:
        return f"{label}={version} is outside the reviewed Spring 6.2.x compatibility line"
    if parsed < SPRING_FLOOR:
        return f"{label}={version} < {SPRING_FLOOR_TEXT}"
    if UNREVIEWED_QUALIFIER.search(version):
        return f"{label}={version} uses an unreviewed qualifier"
    return None

def jetty_failure(label, version):
    parsed = parse_version(version)
    if parsed is None:
        return None
    if parsed[0] < 12:
        return f"{label}={version} is below Jetty 12"
    if parsed[:len(JETTY_LINE)] != JETTY_LINE:
        return f"{label}={version} is outside the reviewed Jetty 12.1.x compatibility line"
    if parsed < JETTY_FLOOR:
        return f"{label}={version} < {JETTY_FLOOR_TEXT}"
    if UNREVIEWED_QUALIFIER.search(version):
        return f"{label}={version} uses an unreviewed qualifier"
    return None

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            name = local_name(child.tag)
            value = (child.text or "").strip()
            properties[name] = value
            if name == "spring.version":
                failure = spring_failure("spring.version", value)
                if failure:
                    failures.append(f"{pom}: {failure}")
            if name == "jetty.version":
                failure = jetty_failure("jetty.version", value)
                if failure:
                    failures.append(f"{pom}: {failure}")

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        if group.startswith("org.springframework"):
            resolved = resolve_property(version, properties)
            failure = spring_failure(f"{group}:{artifact}", resolved)
            if failure:
                display_version = version if version == resolved else f"{version}={resolved}"
                failures.append(f"{pom}: {group}:{artifact}:{display_version}: {failure}")
        if group.startswith("org.eclipse.jetty"):
            resolved = resolve_property(version, properties)
            failure = jetty_failure(f"{group}:{artifact}", resolved)
            if failure:
                display_version = version if version == resolved else f"{version}={resolved}"
                failures.append(f"{pom}: {group}:{artifact}:{display_version}: {failure}")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$runtime_framework_floor_versions" ]; then
    echo "Blocked Spring/Jetty runtime version outside reviewed stable JDK25 lines found in Maven POMs; keep Spring on stable 6.2.x at 6.2.18+ by default, use RC16_ALLOW_SPRING7_EVALUATION=1 only for the reviewed Spring 7.0.x evaluation line at 7.0.7+, and keep Jetty on stable 12.1.x at 12.1.10+" >&2
    echo "$runtime_framework_floor_versions" >&2
    fail=1
fi

