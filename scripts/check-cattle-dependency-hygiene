logback_security_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOOR = (1, 5, 34)
FLOOR_TEXT = "1.5.34"
REVIEWED_LINE = (1, 5)
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []

def parse_version(version):
    normalized = version.strip()
    if not normalized:
        return None
    match = re.match(r"^(\d+)\.(\d+)\.(\d+)(?:[.-]|$)", normalized)
    if not match:
        return None
    return tuple(int(part) for part in match.groups())

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path:
            continue
        match = re.match(r"^(logback-(?:classic|core))-([^/]+)\.jar$", jar.name)
        if not match:
            continue
        artifact, version_text = match.groups()
        version = parse_version(version_text)
        if version is None:
            failures.append(f"{path}: {artifact} has an unparsable version")
        elif version[:len(REVIEWED_LINE)] != REVIEWED_LINE:
            failures.append(f"{path}: {artifact} is outside the reviewed Logback 1.5.x runtime line")
        elif version < FLOOR:
            failures.append(f"{path}: {artifact} < {FLOOR_TEXT}")
        elif UNREVIEWED_QUALIFIER.search(version_text):
            failures.append(f"{path}: {artifact} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$logback_security_floor_jars" ]; then
    echo "Blocked Logback jar outside the reviewed stable line packaged in app; keep Logback 1.5.34+ on the reviewed 1.5.x runtime line for current CVE fixes" >&2
    echo "$logback_security_floor_jars" >&2
    fail=1
fi

slf4j_stable_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOOR = (2, 0, 18)
REVIEWED_LINE = (2, 0)
REVIEWED_ARTIFACT_RE = re.compile(r"^(slf4j-api|log4j-over-slf4j|jcl-over-slf4j|jul-to-slf4j)-(\d+)\.(\d+)\.(\d+)([^/]*)\.jar$")
UNSTABLE_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|milestone|snapshot|rc)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []

if root.exists():
    for jar in sorted(root.rglob("*.jar")):
        path = jar.as_posix()
        if "/WEB-INF/lib/" not in path:
            continue
        match = REVIEWED_ARTIFACT_RE.match(jar.name)
        if not match:
            continue
        artifact, major, minor, patch, qualifier = match.groups()
        version = (int(major), int(minor), int(patch))
        if version[:2] != REVIEWED_LINE:
            failures.append(f"{path}: {artifact} is outside the reviewed SLF4J 2.0.x stable line")
        elif version < FLOOR:
            failures.append(f"{path}: {artifact} < 2.0.18")
        elif UNSTABLE_QUALIFIER.search(qualifier):
            failures.append(f"{path}: {artifact} uses an unstable qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$slf4j_stable_floor_jars" ]; then
    echo "Blocked SLF4J jar outside the reviewed stable floor packaged in app; keep SLF4J API/bridges on stable 2.0.x at 2.0.18+" >&2
    echo "$slf4j_stable_floor_jars" >&2
    fail=1
fi

