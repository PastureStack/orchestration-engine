jmxutils_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (1, 28, 0)
FLOOR_TEXT = "1.28"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if group != "org.weakref" or artifact != "jmxutils":
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        display_version = version if version == resolved else f"{version}={resolved}"
        if parsed is not None and parsed < FLOOR:
            failures.append(f"{pom}: jmxutils org.weakref:jmxutils:{display_version} < {FLOOR_TEXT}")
        elif parsed is not None and parsed[0] != 1:
            failures.append(f"{pom}: jmxutils org.weakref:jmxutils:{display_version} is outside the reviewed 1.x compatibility line")
        elif parsed is not None and UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: jmxutils org.weakref:jmxutils:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$jmxutils_floor_dependencies" ]; then
    echo "Blocked jmxutils dependency outside reviewed stable floor found in Maven POMs; keep org.weakref:jmxutils 1.28+ on the reviewed 1.x line without unreviewed qualifiers" >&2
    echo "$jmxutils_floor_dependencies" >&2
    fail=1
fi

jmxutils_floor_jars=$(
    python3 - <<'PY'
import re
import sys
from pathlib import Path

FLOOR = (1, 28, 0)
FLOOR_TEXT = "1.28"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)
root = Path("code/packaging/app/target")
failures = []
jar_pattern = re.compile(r"^jmxutils-(\d+)\.(\d+)(?:[.-](\d+))?([^/]*)\.jar$")

if root.exists():
    for jar in sorted(root.glob("*/WEB-INF/lib/jmxutils-*.jar")):
        match = jar_pattern.match(jar.name)
        if not match:
            failures.append(f"{jar}: could not parse jmxutils version")
            continue
        major, minor, patch, qualifier = match.groups()
        parsed = (int(major), int(minor), int(patch or "0"))
        if parsed < FLOOR:
            failures.append(f"{jar}: jmxutils {'.'.join(map(str, parsed))} < {FLOOR_TEXT}")
        elif parsed[0] != 1:
            failures.append(f"{jar}: jmxutils {'.'.join(map(str, parsed))} is outside the reviewed 1.x compatibility line")
        elif UNREVIEWED_QUALIFIER.search(qualifier):
            failures.append(f"{jar}: jmxutils uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$jmxutils_floor_jars" ]; then
    echo "Blocked jmxutils jar outside reviewed stable floor packaged in app; keep org.weakref:jmxutils 1.28+ on the reviewed 1.x line without unreviewed qualifiers" >&2
    echo "$jmxutils_floor_jars" >&2
    fail=1
fi

docker_java_floor_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOOR = (3, 7, 1)
FLOOR_TEXT = "3.7.1"
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr|milestone)(?:[.-]|\d|$)", re.IGNORECASE)
ARTIFACTS = {
    "docker-java",
    "docker-java-api",
    "docker-java-core",
    "docker-java-transport",
    "docker-java-transport-httpclient5",
    "docker-java-transport-zerodep",
    "docker-java-transport-okhttp",
}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)(?:[.-](\d+))?(?:[.-]|$)", normalized)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch or "0"))

def read_properties(pom):
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError:
        return {}
    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()
    return properties

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

global_properties = read_properties(Path("code/meta-parent/pom.xml"))
failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(pom))

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if group != "com.github.docker-java" or artifact not in ARTIFACTS:
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        resolved = resolve_property(version, properties)
        parsed = parse_version(resolved)
        display_version = version if version == resolved else f"{version}={resolved}"
        if parsed is not None and parsed < FLOOR:
            failures.append(f"{pom}: docker-java {group}:{artifact}:{display_version} < {FLOOR_TEXT}")
        elif parsed is not None and parsed[:2] != (3, 7):
            failures.append(f"{pom}: docker-java {group}:{artifact}:{display_version} is outside the reviewed 3.7.x compatibility line")
        elif parsed is not None and UNREVIEWED_QUALIFIER.search(resolved):
            failures.append(f"{pom}: docker-java {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$docker_java_floor_dependencies" ]; then
    echo "Blocked docker-java dependency outside reviewed stable floor found in Maven POMs; keep com.github.docker-java artifacts at 3.7.1+ on the reviewed 3.7.x line without unreviewed qualifiers" >&2
    echo "$docker_java_floor_dependencies" >&2
    fail=1
fi

