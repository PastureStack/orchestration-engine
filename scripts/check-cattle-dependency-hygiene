db_driver_effective_scope_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
DRIVERS = {
    ("org.mariadb.jdbc", "mariadb-java-client"): "MariaDB Connector/J",
    ("org.postgresql", "postgresql"): "PostgreSQL JDBC",
    ("com.h2database", "h2"): "H2",
    ("org.hsqldb", "hsqldb"): "HSQLDB",
}
ALLOWED_SCOPES = {"runtime", "test"}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def read_properties(root):
    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()
    return properties

def resolve_property(value, properties):
    match = re.match(r"^\$\{([^}]+)\}$", value.strip())
    if not match:
        return value
    return properties.get(match.group(1), "")

def collect_managed(root, properties):
    managed = {}
    for dep in root.findall(".//m:dependencyManagement/m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        if (group, artifact) not in DRIVERS:
            continue
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        scope = (dep.findtext("m:scope", default="", namespaces=NS) or "").strip()
        managed[(group, artifact)] = {
            "version": resolve_property(version, properties) if version else "",
            "scope": scope,
        }
    return managed

def is_dependency_management_entry(dep, parent_map):
    current = dep
    while current in parent_map:
        current = parent_map[current]
        if local_name(current.tag) == "dependencyManagement":
            return True
    return False

global_root = ET.parse("code/meta-parent/pom.xml").getroot()
global_properties = read_properties(global_root)
global_managed = collect_managed(global_root, global_properties)

failures = []
for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    properties = dict(global_properties)
    properties.update(read_properties(root))
    managed = dict(global_managed)
    managed.update(collect_managed(root, properties))
    parent_map = {child: parent for parent in root.iter() for child in list(parent)}

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        label = DRIVERS.get((group, artifact))
        if label is None:
            continue

        explicit_version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        explicit_scope = (dep.findtext("m:scope", default="", namespaces=NS) or "").strip()
        is_managed = is_dependency_management_entry(dep, parent_map)
        if is_managed:
            version = resolve_property(explicit_version, properties) if explicit_version else ""
            scope = explicit_scope or "compile"
        else:
            managed_driver = managed.get((group, artifact), {})
            version = resolve_property(explicit_version, properties) if explicit_version else managed_driver.get("version", "")
            scope = explicit_scope or managed_driver.get("scope", "") or "compile"

        if not version:
            failures.append(f"{pom}: {label} {group}:{artifact} has no resolved managed runtime/test version")
        if scope not in ALLOWED_SCOPES:
            failures.append(f"{pom}: {label} {group}:{artifact}:{version or '(unresolved)'} has effective scope {scope!r}; keep database drivers runtime or test scoped")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$db_driver_effective_scope_dependencies" ]; then
    echo "Blocked database driver dependency outside reviewed runtime/test scopes found in Maven POMs; keep MariaDB, PostgreSQL, H2, and HSQLDB drivers runtime or test scoped so driver APIs do not become compile-surface dependencies" >&2
    echo "$db_driver_effective_scope_dependencies" >&2
    fail=1
fi

jakarta_api_stable_line_dependencies=$(
    python3 - <<'PY'
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

NS = {"m": "http://maven.apache.org/POM/4.0.0"}
FLOORS = {
    ("jakarta.annotation", "jakarta.annotation-api"): ((3, 0, 0), "3.0.0", (3, 0), "Jakarta Annotation API"),
    ("jakarta.inject", "jakarta.inject-api"): ((2, 0, 1), "2.0.1", (2, 0), "Jakarta Inject API"),
    ("jakarta.persistence", "jakarta.persistence-api"): ((3, 2, 0), "3.2.0", (3, 2), "Jakarta Persistence API"),
    ("jakarta.servlet", "jakarta.servlet-api"): ((6, 1, 0), "6.1.0", (6, 1), "Jakarta Servlet API"),
    ("jakarta.xml.bind", "jakarta.xml.bind-api"): ((4, 0, 5), "4.0.5", (4, 0), "Jakarta XML Bind API"),
}
UNREVIEWED_QUALIFIER = re.compile(r"(?:^|[.-])(alpha|beta|snapshot|rc|b\d+|m\d+|mr)(?:[.-]|\d|$)", re.IGNORECASE)

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def parse_version(version):
    normalized = version.strip()
    if not normalized or normalized.startswith("${"):
        return None
    match = re.match(r"^(\d+)\.(\d+)\.(\d+)(?:[.-]|$)", normalized)
    if not match:
        return None
    return tuple(int(part) for part in match.groups())

def resolve_property(version, properties):
    match = re.match(r"^\$\{([^}]+)\}$", version.strip())
    if not match:
        return version
    return properties.get(match.group(1), "")

failures = []
seen_failures = set()

def add_failure(message):
    if message not in seen_failures:
        seen_failures.add(message)
        failures.append(message)

for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        add_failure(f"{pom}: parse failed: {exc}")
        continue

    properties = {}
    properties_root = root.find("m:properties", NS)
    if properties_root is not None:
        for child in list(properties_root):
            properties[local_name(child.tag)] = (child.text or "").strip()

    managed_versions = {}
    dependency_management = root.find("m:dependencyManagement/m:dependencies", NS)
    if dependency_management is not None:
        for managed_dep in dependency_management.findall("m:dependency", NS):
            managed_group = (managed_dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
            managed_artifact = (managed_dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
            managed_version = (managed_dep.findtext("m:version", default="", namespaces=NS) or "").strip()
            if managed_group and managed_artifact and managed_version:
                managed_versions[(managed_group, managed_artifact)] = managed_version

    for dep in root.findall(".//m:dependencies/m:dependency", NS):
        group = (dep.findtext("m:groupId", default="", namespaces=NS) or "").strip()
        artifact = (dep.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
        config = FLOORS.get((group, artifact))
        if config is None:
            continue
        floor, floor_text, reviewed_line, label = config
        version = (dep.findtext("m:version", default="", namespaces=NS) or "").strip()
        effective_version = version or managed_versions.get((group, artifact), "")
        if not effective_version:
            continue
        resolved = resolve_property(effective_version, properties)
        parsed = parse_version(resolved)
        display_version = effective_version if effective_version == resolved else f"{effective_version}={resolved}"
        line_text = ".".join(str(part) for part in reviewed_line)
        if parsed is None:
            add_failure(f"{pom}: {group}:{artifact}:{display_version} is not a concrete reviewed version")
        elif parsed[:len(reviewed_line)] != reviewed_line:
            add_failure(f"{pom}: {group}:{artifact}:{display_version} is outside the reviewed {label} {line_text}.x line")
        elif parsed < floor:
            add_failure(f"{pom}: {group}:{artifact}:{display_version} < {floor_text}")
        elif UNREVIEWED_QUALIFIER.search(resolved):
            add_failure(f"{pom}: {group}:{artifact}:{display_version} uses an unreviewed qualifier")

print("\n".join(failures))
sys.exit(0)
PY
)
if [ -n "$jakarta_api_stable_line_dependencies" ]; then
    echo "Blocked Jakarta API dependency outside reviewed stable lines found in Maven POMs; keep Annotation 3.0.x, Inject 2.0.1, Persistence 3.2.x, Servlet 6.1.x, and XML Bind 4.0.x until an explicit compatibility slice reviews newer MR/milestone/spec lines" >&2
    echo "$jakarta_api_stable_line_dependencies" >&2
