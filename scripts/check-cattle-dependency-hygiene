    "javadocDirectory",
    "jdkToolchain",
    "links",
    "offlineLinks",
    "release",
    "skip",
    "skippedModules",
    "source",
    "sourceFileExcludes",
    "sourceFileIncludes",
    "sourcepath",
    "subpackages",
}

def local_name(tag):
    return tag.rsplit("}", 1)[-1]

def plugin_key(plugin):
    group = (plugin.findtext("m:groupId", default="org.apache.maven.plugins", namespaces=NS) or "org.apache.maven.plugins").strip()
    artifact = (plugin.findtext("m:artifactId", default="", namespaces=NS) or "").strip()
    return group, artifact

def text(element):
    return " ".join("".join(element.itertext()).split())

failures = []

for pom in sorted(Path(".").rglob("pom.xml")):
    if "target" in pom.parts or ".git" in pom.parts:
        continue
    try:
        root = ET.parse(pom).getroot()
    except ET.ParseError as exc:
        failures.append(f"{pom}: parse failed: {exc}")
        continue

    if root.find("m:reporting", NS) is not None:
        failures.append(f"{pom}: Maven <reporting> surface is blocked until JDK25 Javadoc/report generation is explicitly validated")

    for properties in root.findall(".//m:properties", NS):
        for prop in list(properties):
            name = local_name(prop.tag)
            if name in BLOCKED_PROPERTIES:
                failures.append(f"{pom}: Maven Javadoc/reporting property <{name}> is blocked so JDK25 doclint, source/release, toolchain, doclet, and report surfaces stay reviewed")

    for plugin in root.findall(".//m:plugin", NS):
        key = plugin_key(plugin)
        if key in BLOCKED_BUILD_PLUGINS:
            failures.append(f"{pom}: Maven build plugin {key[0]}:{key[1]} is blocked until JDK25 Javadoc/site behavior is reviewed")
        if key in BLOCKED_REPORTING_PLUGINS:
            failures.append(f"{pom}: Maven reporting plugin {key[0]}:{key[1]} is blocked until JDK25 report generation is reviewed")

        if key != ("org.apache.maven.plugins", "maven-javadoc-plugin"):
            continue
        for configuration in plugin.findall(".//m:configuration", NS):
            for child in list(configuration):
                name = local_name(child.tag)
                if name in BLOCKED_CONFIGURATION:
                    value = text(child)
                    rendered = f"<{name}>{value}</{name}>" if value else f"<{name}>"
                    failures.append(f"{pom}: Maven Javadoc configuration {rendered} is blocked until JDK25 doclint/source/toolchain/report behavior is reviewed")

print("\n".join(failures))
sys.exit(0)
PY
)
