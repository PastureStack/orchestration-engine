#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

expected_major=${RC16_CATTLE_EXPECTED_CLASS_MAJOR:-69}
runner_image=${RC16_CATTLE_BYTECODE_JDK_IMAGE:-}

run_local()
{
    local python_cmd=${PYTHON:-}
    if [ -z "$python_cmd" ]; then
        for candidate in python3 python; do
            if command -v "$candidate" >/dev/null 2>&1 && "$candidate" -c 'import sys' >/dev/null 2>&1; then
                python_cmd=$candidate
                break
            fi
        done
    fi

    if [ -z "$python_cmd" ]; then
        return 2
    fi

    "$python_cmd" - "$expected_major" <<'PY'
import os
import subprocess
import sys
import zipfile
from pathlib import Path

expected = int(sys.argv[1])
failures = []
class_count = 0
jar_class_count = 0
jar_count = 0


def major_for_class_file(path: Path) -> int:
    data = path.read_bytes()
    if len(data) < 8 or data[:4] != b"\xca\xfe\xba\xbe":
        raise ValueError("not a Java class file")
    return int.from_bytes(data[6:8], "big")


def major_for_class_bytes(data: bytes) -> int:
    if len(data) < 8 or data[:4] != b"\xca\xfe\xba\xbe":
        raise ValueError("not a Java class entry")
    return int.from_bytes(data[6:8], "big")

for classes_dir in sorted(Path("code").glob("**/target/classes")):
    if "target/generated-sources" in str(classes_dir):
        continue
    for class_file in sorted(classes_dir.rglob("*.class")):
        class_count += 1
        major = major_for_class_file(class_file)
        if major != expected:
            failures.append(("target-class", str(class_file), major))

war_libs = sorted(Path("code/packaging/app/target").glob("*/WEB-INF/lib/cattle-*.jar"))
for jar_path in war_libs:
    jar_count += 1
    with zipfile.ZipFile(jar_path) as jar:
        for entry in sorted(name for name in jar.namelist() if name.endswith(".class")):
            jar_class_count += 1
            major = major_for_class_bytes(jar.read(entry))
            if major != expected:
                failures.append(("packaged-jar-class", f"{jar_path}!/{entry}", major))

if class_count == 0:
    failures.append(("target-class-count", "code/**/target/classes", 0))
if jar_count == 0:
    failures.append(("packaged-cattle-jar-count", "code/packaging/app/target/*/WEB-INF/lib/cattle-*.jar", 0))
if jar_class_count == 0:
    failures.append(("packaged-jar-class-count", "code/packaging/app/target/*/WEB-INF/lib/cattle-*.jar", 0))

for kind, path, actual in failures[:100]:
    print(f"CATTLE_JDK25_BYTECODE_FAIL kind={kind} actual={actual} expected={expected} path={path}")
if len(failures) > 100:
    print(f"CATTLE_JDK25_BYTECODE_FAIL_MORE count={len(failures)-100}")

print(f"target_class_count={class_count}")
print(f"packaged_cattle_jar_count={jar_count}")
print(f"packaged_cattle_jar_class_count={jar_class_count}")
print(f"failure_count={len(failures)}")
if failures:
    sys.exit(1)
print(f"CATTLE_JDK25_BYTECODE_OK expected_major={expected}")
PY
}

if run_local; then
    exit 0
else
    local_status=$?
fi
if [ "$local_status" -ne 2 ]; then
    exit "$local_status"
fi

if [ -n "$runner_image" ] && command -v docker >/dev/null 2>&1; then
    docker run --rm -v "$repo_root:/work:ro" -w /work \
        -e RC16_CATTLE_EXPECTED_CLASS_MAJOR="$expected_major" \
        "$runner_image" scripts/check-cattle-jdk25-bytecode
    exit 0
fi

echo "python3 is required for cattle JDK25 bytecode audit" >&2
exit 2
